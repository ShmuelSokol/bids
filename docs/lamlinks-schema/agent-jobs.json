  {
    "job_id": "BE66E366-3FE3-4A79-ADFF-A064050A0DF5",
    "job_name": "QoEMetrics_Purge",
    "enabled": 1,
    "description": "Task to purge QoE data",
    "steps": [
      {
        "job_id": "BE66E366-3FE3-4A79-ADFF-A064050A0DF5",
        "step_id": 1,
        "step_name": "Check mirroring step",
        "subsystem": "TSQL",
        "command": "\r\ndeclare @_MirroringRole int\r\nset @_MirroringRole = (\r\n    select mirroring_role\r\n      from sys.database_mirroring\r\n     where database_id = DB_ID('QoEMetrics')\r\n     )\r\nif (@_MirroringRole is not NULL and @_MirroringRole = 2) begin\r\n    raiserror('Database is mirrored', 16, 1)\r\nend\r\nelse begin\r\n    print ('Database is not mirrored')\r\nend\r\n",
        "database_name": "msdb"
      },
      {
        "job_id": "BE66E366-3FE3-4A79-ADFF-A064050A0DF5",
        "step_id": 2,
        "step_name": "Purge step",
        "subsystem": "TSQL",
        "command": "\r\ndeclare @_EnablePurge bit\r\ndeclare @_KeepQoEDataForDays int\r\ndeclare @_SecondsToKeepData int\r\ndeclare @_PurgeHour int\r\ndeclare @_CurrentHour int\r\nselect @_EnablePurge = EnablePurge,\r\n       @_KeepQoEDataForDays = KeepQoEDataForDays,\r\n       @_PurgeHour = PurgeHour\r\n  from dbo.PurgeSettings\r\n where Id = 1\r\nset @_SecondsToKeepData = @_KeepQoEDataForDays * 24 * 60 * 60\r\nset @_CurrentHour = datepart(hour, getdate())\r\nif (@_EnablePurge = 1)\r\nbegin\r\n    if (@_CurrentHour = @_PurgeHour) begin\r\n        exec dbo.QoePurgeOutdatedReports\r\n        @_CallRecordRetentionSeconds = @_SecondsToKeepData,\r\n        @_MaxSecondsToExecute = 3600\r\n        print ('QoE purge successfully completed.')\r\n    end\r\n    else\r\n    begin\r\n        print ('QoE purge skipped, only run during the purge hour. Current hour: ' + \r\n               convert(varchar(10),@_CurrentHour) + \r\n               ' Purge hour: ' + \r\n               convert(varchar(10),@_PurgeHour))\r\n    end\r\nend\r\nelse\r\nbegin\r\n    print ('QoE purge skipped, EnablePurge = false')\r\nend\r\n",
        "database_name": "QoEMetrics"
      }
    ],
    "schedules": [
      {
        "job_id": "BE66E366-3FE3-4A79-ADFF-A064050A0DF5",
        "schedule_name": "QoEMetrics_Purge_Schedule",
        "freq_type": 4,
        "freq_interval": 1,
        "freq_subday_type": 8,
        "freq_subday_interval": 1,
        "active_start_time": 0
      }
    ]
  },
