  {
    "job_id": "852E3B83-22DD-4AE3-8FFB-3E2DC96D07E1",
    "job_name": "LcsCDR_Purge",
    "enabled": 1,
    "description": "Task to purge call detail and error report records",
    "steps": [
      {
        "job_id": "852E3B83-22DD-4AE3-8FFB-3E2DC96D07E1",
        "step_id": 1,
        "step_name": "Check mirroring step",
        "subsystem": "TSQL",
        "command": "\r\ndeclare @_MirroringRole int\r\nset @_MirroringRole = (\r\n    select mirroring_role\r\n      from sys.database_mirroring\r\n     where database_id = DB_ID('LcsCDR')\r\n     )\r\nif (@_MirroringRole is not NULL and @_MirroringRole = 2) begin\r\n    raiserror('Database is mirrored', 16, 1)\r\nend\r\nelse begin\r\n    print ('Database is not mirrored')\r\nend\r\n",
        "database_name": "msdb"
      },
      {
        "job_id": "852E3B83-22DD-4AE3-8FFB-3E2DC96D07E1",
        "step_id": 2,
        "step_name": "Purge step",
        "subsystem": "TSQL",
        "command": "\r\ndeclare @_EnablePurge bit\r\ndeclare @_KeepCallDetailForDays int\r\ndeclare @_SecondsToKeepRecords int\r\ndeclare @_KeepErrorReportForDays int\r\ndeclare @_SecondsToKeepDiagnostic int\r\ndeclare @_PurgeHour int\r\ndeclare @_CurrentHour int\r\nselect @_EnablePurge = EnablePurge,\r\n       @_KeepCallDetailForDays = KeepCallDetailForDays,\r\n       @_KeepErrorReportForDays = KeepErrorReportForDays,\r\n       @_PurgeHour = PurgeHour\r\n  from dbo.PurgeSettings\r\n where Id = 1\r\nset @_SecondsToKeepRecords = @_KeepCallDetailForDays * 24 * 60 * 60\r\nset @_SecondsToKeepDiagnostic = @_KeepErrorReportForDays * 24 * 60 * 60\r\nset @_CurrentHour = datepart(hour, getdate())\r\nif (@_EnablePurge = 1)\r\nbegin\r\n    if (@_CurrentHour = @_PurgeHour) begin\r\n        exec dbo.RtcCleanupDB\r\n            @_SecondsToKeepRecords = @_SecondsToKeepRecords,\r\n            @_SecondsToKeepDiagnostic = @_SecondsToKeepDiagnostic,\r\n            @_MaxSecondsToExecute = 7200\r\n        print ('CDR purge successfully completed.')\r\n    end\r\n    else\r\n    begin\r\n        print ('CDR purge skipped, only run during the purge hour. Current hour: ' + \r\n               convert(varchar(10),@_CurrentHour) + \r\n               ' Purge hour: ' + \r\n               convert(varchar(10),@_PurgeHour))\r\n    end\r\nend\r\nelse\r\nbegin\r\n    print ('CDR purge skipped, EnablePurge = false')\r\nend\r\n",
        "database_name": "LcsCDR"
      }
    ],
    "schedules": [
      {
        "job_id": "852E3B83-22DD-4AE3-8FFB-3E2DC96D07E1",
        "schedule_name": "LcsCDR_Purge_Schedule",
        "freq_type": 4,
        "freq_interval": 1,
        "freq_subday_type": 8,
        "freq_subday_interval": 1,
        "active_start_time": 0
      }
    ]
  },
