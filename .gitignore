# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Claude Code (lock files are local-only, settings + hooks are shared)
.claude/scheduled_tasks.lock
.claude/settings.local.json

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# discovery data (too large for git)
/data/

# local snapshot/diagnostic output
/tmp/

# reverse-engineering strings dumps (~32 MB; regenerate via rev-eng/README.md)
/rev-eng/strings/*.txt
